PORT=3000
API_KEY=your_proxy_api_key

# Single account (legacy)
QWEN_EMAIL=your_email@example.com
QWEN_PASSWORD=your_password

# Cache Compression (Brotli)
CACHE_COMPRESSION_ENABLED=true  # Enables Brotli compression for cache values
CACHE_COMPRESSION_THRESHOLD=1024 # Minimum size in bytes to trigger compression
CACHE_COMPRESSION_LEVEL=6       # Brotli compression level (1-11, default: 6)

# Topic Detection
TOPIC_DETECTION_ENABLED=true    # Enables topic change detection between turns
TOPIC_DETECTION_CONFIDENCE=0.7  # Jaccard similarity threshold to consider a topic change (0-1)

# Context Preservation (LLM Summarization)
CONTEXT_SUMMARIZATION_ENABLED=true   # Enables summarization of old messages via LLM
CONTEXT_SUMMARIZATION_MODEL=qwen3.5-flash # Model used for summarization (must exist in /v1/models)
CONTEXT_SUMMARIZATION_TIMEOUT=15000  # Timeout in milliseconds for the summarization call
CONTEXT_MIN_MESSAGES_TO_KEEP=4       # Minimum number of recent messages preserved in full

BROWSER=chromium
# Multiple accounts (format: email1:password1,email2:password2)
# QWEN_ACCOUNTS=user1@example.com:pass1,user2@example.com:pass2
